# Shadow Agent local development environment
# Copy this file to backend/.env and replace the placeholder values.

SHADOW_AGENT_ADMIN_API_KEY=replace-with-long-random-admin-key
SHADOW_AGENT_CLIENT_API_KEY=replace-with-long-random-client-key
SHADOW_AGENT_JWT_SECRET=replace-with-a-random-string-at-least-32-characters
SHADOW_AGENT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
